<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<!--https://github.com/abel533/Mapper/wiki/4.1.mappergenerator-->
<!--suppress MybatisGenerateCustomPluginInspection -->
<generatorConfiguration>
    <context id="Mysql" targetRuntime="MyBatis3Simple" defaultModelType="flat">
        <property name="javaFileEncoding" value="UTF-8"/>
        <property name="useMapperCommentGenerator" value="true"/>

        <plugin type="tk.mybatis.mapper.generator.MapperPlugin">
            <property name="mappers" value="tk.mybatis.mapper.common.Mapper"/>
            <property name="caseSensitive" value="true"/>
            <property name="forceAnnotation" value="true"/>
            <!--            <property name="beginningDelimiter" value="`"/>-->
            <!--            <property name="endingDelimiter" value="`"/>-->
            <!--            <property name="generateColumnConsts" value="true"/>-->
            <property name="lombok" value="Getter,Setter,ToString,Accessors"/>
        </plugin>

        <jdbcConnection driverClass="com.mysql.cj.jdbc.Driver"
                        connectionURL="jdbc:mysql://localhost:3301/easy-agent?useSSL=false&amp;serverTimezone=UTC&amp;characterEncoding=UTF-8"
                        userId="root"
                        password="123456">
        </jdbcConnection>

        <!--MyBatis 生成器只需要生成 Model-->
        <javaModelGenerator targetPackage="com.aaa.easyagent.core.domain.DO"
                            targetProject="src\main\java\"/>
        <sqlMapGenerator targetPackage="mbg.mapper"
                         targetProject="src\main\resources"/>

        <javaClientGenerator targetPackage="com.aaa.easyagent.core.mapper"
                             targetProject="src\main\java\"
                             type="XMLMAPPER"/>


        <table tableName="ea_agent" mapperName="EaAgentDAO" domainObjectName="EaAgentDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_function" mapperName="EaFunctionDAO" domainObjectName="EaFunctionDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_tool_config" mapperName="EaToolConfigDAO" domainObjectName="EaToolConfigDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_knowledge_base" mapperName="EaKnowledgeBaseDAO" domainObjectName="EaKnowledgeBaseDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_knowledge_relation" mapperName="EaKnowledgeRelationDAO" domainObjectName="EaKnowledgeRelationDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>
        <table tableName="ea_tool_relation" mapperName="EaToolRelationDAO" domainObjectName="EaToolRelationDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>


        <table tableName="ea_chat_conversation" mapperName="EaChatConversationDAO" domainObjectName="EaChatConversationDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_chat_message" mapperName="EaChatMessageDAO" domainObjectName="EaChatMessageDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_model_platform" mapperName="EaModelPlatformDAO" domainObjectName="EaModelPlatformDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_iam_user" mapperName="EaIamUserDAO" domainObjectName="EaIamUserDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_iam_role" mapperName="EaIamRoleDAO" domainObjectName="EaIamRoleDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_iam_permission" mapperName="EaIamPermissionDAO" domainObjectName="EaIamPermissionDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_iam_user_role" mapperName="EaIamUserRoleDAO" domainObjectName="EaIamUserRoleDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_iam_role_permission" mapperName="EaIamRolePermissionDAO" domainObjectName="EaIamRolePermissionDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_mcp_config" mapperName="EaMcpConfigDAO" domainObjectName="EaMcpConfigDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

        <table tableName="ea_mcp_relation" mapperName="EaMcpRelationDAO" domainObjectName="EaMcpRelationDO">
            <generatedKey identity="true" column="id" sqlStatement="JDBC"/>
        </table>

    </context>
</generatorConfiguration>
